{
  "expo": {
    "name": "Harcamalarım",
    "slug": "mobilHarcamalarimApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1117"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1117"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.kaanhaciomeroglu.mobilHarcamalarimApp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "harcamalarim",
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7fdbb862-5000-4d53-bcdf-990e4b06d98d"
      }
    },
    "owner": "kaanhaciomeroglu"
  }
}
